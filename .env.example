# Copy to .env and fill in. Never commit .env.
# Used by docker-compose.local.yml

# Cloudflare Worker origin (production or wrangler tunnel)
API_BASE=https://motion.productions

# Must match Worker secret MOTION_API_SECRET (wrangler secret put MOTION_API_SECRET)
MOTION_API_SECRET=replace-me-with-a-long-random-string

# Optional: same value as Worker VIDEO_AI_RENDER_SECRET (Node FFmpeg render)
VIDEO_AI_RENDER_SECRET=

# Optional: OpenAI on video-ai render host (TTS only)
OPENAI_API_KEY=
