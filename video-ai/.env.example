# Local render server (copy to .env — never commit secrets)
# OPENAI_API_KEY=sk-...   # Required only if recipes use meta.audio.narration
# VIDEO_AI_RENDER_SECRET=...
# VIDEO_AI_RENDER_PORT=8788
# VIDEO_AI_FONT=/path/to/font.ttf
#
# Async jobs (/jobs): S3-compatible R2 + callback to Worker (set on Railway for production)
# VIDEO_AI_R2_ACCOUNT_ID=...
# VIDEO_AI_R2_ACCESS_KEY_ID=...
# VIDEO_AI_R2_SECRET_ACCESS_KEY=...
# VIDEO_AI_R2_BUCKET=motion-productions-videos
# VIDEO_AI_R2_ENDPOINT=   # optional; default https://${VIDEO_AI_R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# VIDEO_AI_WORKER_ORIGIN=https://motion.productions,https://www.motion.productions   # prod: lock completeUrl (comma-separated)
